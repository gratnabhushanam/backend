PORT=8888
LEGACY_PORT=5000
NODE_ENV=development

# Database mode (current default)
DB_DIALECT=sqlite
SQLITE_STORAGE=./data/gita_wisdom.sqlite
DB_SYNC_ALTER=true

# Comma-separated frontend origins for CORS allowlist in production
# Example: https://gita-wisdom.vercel.app,https://www.gita-wisdom.com
CORS_ALLOWED_ORIGINS=

# MySQL values are optional and used only when DB_DIALECT=mysql
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_NAME=gita_wisdom

JWT_SECRET=replace_with_strong_secret

# Backend-only admin credentials (never put these in frontend code)
ADMIN_NAME=Gita Admin
ADMIN_EMAIL=admin@gitawisdom.local
ADMIN_PASSWORD=change_this_to_a_strong_password

# Gmail OTP email settings (use a Gmail App Password, not your normal Gmail password)
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password
EMAIL_FROM_NAME=Gita Wisdom
ALLOW_OTP_PREVIEW=false
OTP_EXPIRY_MINUTES=10
